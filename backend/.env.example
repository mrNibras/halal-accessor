# ─── Database (Neon Serverless PostgreSQL) ───
# Get connection strings from: https://console.neon.tech/
# DATABASE_URL = Pooled connection (for app runtime)
# DIRECT_URL   = Direct connection (for Prisma migrations)
# SHADOW_DATABASE_URL = Direct connection to empty DB (for dev migrations)
DATABASE_URL="postgresql://halal_user:password@ep-cool-mountain-123456.us-east-2.aws.neon.tech/halal_accessor?sslmode=require"
DIRECT_URL="postgresql://halal_user:password@ep-cool-mountain-123456-pooler.us-east-2.aws.neon.tech/halal_accessor?sslmode=require&pgbouncer=true"
SHADOW_DATABASE_URL="postgresql://halal_user:password@ep-cool-mountain-123456-pooler.us-east-2.aws.neon.tech/halal_accessor_shadow?sslmode=require&pgbouncer=true"

# JWT Secrets (generate your own with: openssl rand -hex 32)
JWT_ACCESS_SECRET=generate_your_own_256bit_hex_secret
JWT_REFRESH_SECRET=generate_your_own_256bit_hex_secret

# Server
PORT=5000
NODE_ENV=development

# Shop Location (Bale Robe, Ethiopia)
SHOP_LAT=7.1221
SHOP_LNG=40.0098

# Google Maps
GOOGLE_MAPS_API_KEY=your_key_here

# Chapa Payment
CHAPA_SECRET_KEY=your_key_here
CHAPA_PUBLIC_KEY=your_key_here
CHAPA_WEBHOOK_SECRET=your_key_here
CHAPA_CALLBACK_URL=http://localhost:5173/payment/callback
CHAPA_BASE_URL=https://api.chapa.co

# Frontend URL
FRONTEND_URL=http://localhost:5173
